# Copy to .env and fill in. Never commit .env.
# --- Database (Postgres + PostGIS) ---
DATABASE_URL=postgres://stickerboard:stickerboard@localhost:5432/stickerboard
TEST_DATABASE_URL=postgres://stickerboard:stickerboard@localhost:5432/stickerboard_test

# --- Redis (sessions / realtime state) ---
REDIS_URL=redis://localhost:6379

# --- S3-compatible object storage (MinIO in dev) ---
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=stickerboard-assets

# --- Auth ---
JWT_SECRET=change-me-in-prod
JWT_EXPIRES_IN=7d

# --- App ---
API_PORT=3000
NODE_ENV=development
